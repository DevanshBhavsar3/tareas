TAREAS_PRIMARY.ENV="local"

TAREAS_SERVER.PORT="3001"
TAREAS_SERVER.READ_TIMEOUT="30"
TAREAS_SERVER.WRITE_TIMEOUT="30"
TAREAS_SERVER.IDLE_TIMEOUT="60"
TAREAS_SERVER.CORS_ALLOWED_ORIGINS="http://localhost:3000"

TAREAS_DATABASE.HOST="localhost"
TAREAS_DATABASE.PORT="5432"
TAREAS_DATABASE.USER="postgres"
TAREAS_DATABASE.PASSWORD="secret"
TAREAS_DATABASE.NAME="tareas"
TAREAS_DATABASE.SSL_MODE="disable"
TAREAS_DATABASE.MAX_OPEN_CONNS="25"
TAREAS_DATABASE.MAX_IDLE_CONNS="25"
TAREAS_DATABASE.CONN_MAX_LIFETIME="300"
TAREAS_DATABASE.CONN_MAX_IDLE_TIME="300"

TAREAS_AUTH.SECRET_KEY=""

TAREAS_INTEGRATION.RESEND_API_KEY=""

TAREAS_REDIS.ADDRESS="localhost:6379"
TAREAS_REDIS.PASSWORD="x"
TAREAS_REDIS.TLS_ENABLED="true"

# ============================================================================
# AWS CONFIGURATION
# ============================================================================

TAREAS_AWS.REGION="x"
TAREAS_AWS.ACCESS_KEY_ID="x"
TAREAS_AWS.SECRET_ACCESS_KEY="x"
TAREAS_AWS.UPLOAD_BUCKET="x"
TAREAS_AWS.ENDPOINT_URL="x"

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================

# Service Identity
TAREAS_OBSERVABILITY.SERVICE_NAME="tareas"
TAREAS_OBSERVABILITY.ENVIRONMENT="development"

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Basic Logging Settings
TAREAS_OBSERVABILITY.LOGGING.LEVEL="debug"
TAREAS_OBSERVABILITY.LOGGING.FORMAT="json"

# ============================================================================
# NEW RELIC CONFIGURATION
# ============================================================================

# New Relic APM
TAREAS_OBSERVABILITY.NEW_RELIC.LICENSE_KEY=""
TAREAS_OBSERVABILITY.NEW_RELIC.USER_KEY=""
TAREAS_OBSERVABILITY.NEW_RELIC.APP_LOG_FORWARDING_ENABLED="true"
TAREAS_OBSERVABILITY.NEW_RELIC.DISTRIBUTED_TRACING_ENABLED="true"
TAREAS_OBSERVABILITY.NEW_RELIC.DEBUG_LOGGING="false"
